---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Atif Ali — Senior Software Architect",
  description = "Senior Software Architect with 20+ years building production systems across Laravel, Python/FastAPI, React/TypeScript, Node.js, and Golang.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-200 antialiased">
    <div
      class="pointer-events-none fixed inset-0 z-0 overflow-hidden"
      aria-hidden="true"
    >
      <div
        class="absolute -top-40 left-1/2 h-[500px] w-[900px] -translate-x-1/2 rounded-full bg-indigo-500/20 blur-[120px]"
      >
      </div>
      <div
        class="absolute top-[30%] right-0 h-[400px] w-[600px] rounded-full bg-purple-500/10 blur-[120px]"
      >
      </div>
      <div
        class="absolute bottom-0 left-0 h-[400px] w-[600px] rounded-full bg-pink-500/10 blur-[120px]"
      >
      </div>
    </div>
    <div class="relative z-10 flex min-h-screen flex-col">
      <Nav />
      <main class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
