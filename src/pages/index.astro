---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects, featuredProjects } from "../data/projects";
import { services } from "../data/services";
import { now } from "../data/now";

// Pools used by the popover JS to pick 5 random items per refresh.
// Each item: { title, meta, href }.
const allProjectItems = projects.map((p) => ({
  title: p.name,
  meta: p.year + " · " + p.category,
  href: `/projects/${p.slug}`,
}));

const allServiceItems = services.map((s) => ({
  title: s.name,
  meta: s.category + (s.projectName ? " · " + s.projectName : ""),
  href: `/services#${s.slug}`,
}));

// Stacks are an explicit list since they aren't a separate data file yet.
const allStackItems = [
  { name: "Python / FastAPI",        category: "Backend" },
  { name: "Next.js / TypeScript",    category: "Full-stack" },
  { name: "React / TypeScript",      category: "Frontend" },
  { name: "React Native / Expo",     category: "Mobile" },
  { name: "Golang",                  category: "Backend" },
  { name: "Node.js / TypeScript",    category: "Backend" },
  { name: "Ruby on Rails 8",         category: "Backend" },
  { name: "Laravel 12 / PHP 8.2",    category: "Backend" },
  { name: "PostgreSQL + pgvector",   category: "Data" },
  { name: "Redis + BullMQ",          category: "Data" },
  { name: "Elasticsearch",           category: "Data" },
  { name: "Docker + Compose",        category: "Platform" },
  { name: "AWS",                     category: "Platform" },
  { name: "Cloudflare",              category: "Platform" },
  { name: "n8n",                     category: "Automation" },
  { name: "Lua / Kong",              category: "Infra" },
].map((s) => ({
  title: s.name,
  meta: s.category,
  href: `/about#toolbox`,
}));

const stats = [
  {
    id: "years",
    value: "20+",
    target: 20,
    suffix: "+",
    label: "Years shipping",
    moreLabel: "View experience",
    moreHref: "/about#experience",
    pool: "services",
  },
  {
    id: "projects",
    value: "10+",
    target: 10,
    suffix: "+",
    label: "Portfolio projects",
    moreLabel: "View all projects",
    moreHref: "/projects",
    pool: "projects",
  },
  {
    id: "services",
    value: "12+",
    target: 12,
    suffix: "+",
    label: "Services architected",
    moreLabel: "View all services",
    moreHref: "/services",
    pool: "services",
  },
  {
    id: "stacks",
    value: "10+",
    target: 10,
    suffix: "+",
    label: "Production stacks",
    moreLabel: "View toolbox",
    moreHref: "/about#toolbox",
    pool: "stacks",
  },
];

const specialties = [
  {
    title: "Multi-tenant SaaS",
    description:
      "Real tenant isolation via global scopes or Postgres RLS, not URL prefixes or handwaving. Billing, auth, and admin consoles that survive real customers.",
    icon: "M4 6a2 2 0 012-2h12a2 2 0 012 2v2H4V6zm16 4H4v8a2 2 0 002 2h12a2 2 0 002-2v-8zM8 14h4",
  },
  {
    title: "AI & LLM platforms",
    description:
      "Agentic systems with LangGraph, RAG over pgvector, MCP server integrations, and Langfuse observability. Claude and OpenAI into production workflows.",
    icon: "M12 4.5v15m7.5-7.5h-15",
  },
  {
    title: "Fintech & payments",
    description:
      "Cross-border remittance, Stripe Cashier billing, KYC and AML rule engines, and provider-agnostic interfaces so counterparties are a swap, not a rewrite.",
    icon: "M3 6l9 4 9-4M3 10l9 4 9-4M3 14l9 4 9-4",
  },
  {
    title: "APIs at scale",
    description:
      "REST APIs serving millions of requests. Sanctum, JWT, HMAC-signed webhooks, rate limiting, and idempotency patterns that actually hold up in production.",
    icon: "M7 8l-4 4 4 4m10-8l4 4-4 4M14 4l-4 16",
  },
];
---

<Layout
  title="Atif Ali — Senior Software Architect"
  description="Senior Software Architect with 20+ years shipping multi-tenant SaaS, AI platforms, fintech, and APIs at scale. CaseFlow, Zarpay, Axon, Reelm, and more."
>
  <section class="relative mx-auto max-w-6xl px-6 pt-14 pb-12 md:pt-20">
    <div class="flex flex-col items-start gap-5">
      <div
        class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-slate-300 backdrop-blur"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"
          ></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"
          ></span>
        </span>
        Available for senior contract work
      </div>

      <h1
        class="max-w-4xl text-4xl font-bold leading-[1.1] tracking-tight text-white md:text-5xl lg:text-6xl"
      >
        I build <span class="gradient-text">production systems</span> that
        actually hold up under real load.
      </h1>
      <p class="max-w-2xl text-base text-slate-400 md:text-lg">
        Senior Software Architect with 20+ years across Python, FastAPI,
        React, Node, Golang, and Laravel. Multi-tenant SaaS, AI platforms,
        fintech products, and APIs at scale.
      </p>
      <div class="mt-2 flex flex-wrap gap-3">
        <a
          href="/projects"
          class="theme-cta group inline-flex items-center gap-2 rounded-lg px-5 py-3 text-sm font-semibold text-white transition-all"
        >
          View case studies
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14M13 5l7 7-7 7"></path>
          </svg>
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 rounded-lg border border-white/15 bg-white/5 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/10"
        >
          Get in touch
        </a>
      </div>
    </div>

    <div
      class="mt-16 grid grid-cols-2 gap-6 border-t border-white/5 pt-10 md:grid-cols-4"
    >
      {
        stats.map((stat) => (
          <div class="relative" data-popover-root>
            <button
              type="button"
              data-popover-trigger={stat.id}
              data-popover-pool={stat.pool}
              aria-expanded="false"
              aria-controls={`popover-${stat.id}`}
              class="group block w-full rounded-lg p-1 text-left transition-all hover:-translate-y-0.5 cursor-pointer"
            >
              <div
                class="text-3xl font-bold text-white transition-colors group-hover:text-indigo-300 md:text-4xl"
                data-count-target={stat.target}
                data-count-suffix={stat.suffix}
              >
                {stat.value}
              </div>
              <div class="mt-1 inline-flex items-center gap-1 text-sm text-slate-400 transition-colors group-hover:text-slate-200">
                <span>{stat.label}</span>
                <svg
                  class="h-3 w-3 opacity-60 transition-transform"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M6 9l6 6 6-6" />
                </svg>
              </div>
            </button>
            <div
              id={`popover-${stat.id}`}
              data-popover-target={stat.id}
              role="dialog"
              aria-label={stat.label}
              hidden
              class="absolute left-0 top-full z-30 mt-2 w-72 origin-top-left rounded-xl border border-white/10 bg-slate-950/95 p-3 shadow-2xl shadow-indigo-500/10 backdrop-blur-xl md:w-80"
            >
              <ul data-popover-list class="space-y-1" />
              <a
                href={stat.moreHref}
                class="mt-2 flex items-center justify-between rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm font-semibold text-white transition-all hover:bg-white/10"
              >
                {stat.moreLabel}
                <svg
                  class="h-4 w-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M5 12h14M13 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        ))
      }
    </div>

    <script
      type="application/json"
      id="popover-pools"
      set:html={JSON.stringify({
        projects: allProjectItems,
        services: allServiceItems,
        stacks: allStackItems,
      })}
    />
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-widest text-indigo-300">
          Currently building
        </p>
        <h2 class="mt-2 text-2xl font-bold tracking-tight text-white md:text-3xl">
          Right now, {now.asOf}
        </h2>
      </div>
      <p class="text-sm text-slate-500">
        Active focus, updated every few weeks.
      </p>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-2">
      {
        now.items.map((item) => (
          <a
            href={`/projects/${item.slug}`}
            class="group relative flex flex-col rounded-2xl border border-white/10 bg-slate-900/40 p-6 backdrop-blur-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-white/20 hover:bg-slate-900/70"
          >
            <div class="flex items-center gap-2">
              <span class="relative flex h-2 w-2">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
              </span>
              <span class="text-[11px] font-semibold uppercase tracking-widest text-emerald-300">
                {item.status}
              </span>
            </div>
            <h3 class="mt-3 text-xl font-semibold text-white">
              {item.project}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-400">
              {item.description}
            </p>
            <div class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-slate-300 transition-colors group-hover:text-white">
              Read case study
              <svg
                class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14M13 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-widest text-indigo-300">
          Featured work
        </p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-white md:text-4xl">
          Products I've shipped
        </h2>
        <p class="mt-2 max-w-2xl text-slate-400">
          Selected case studies across SaaS, AI, fintech, streaming, and
          mobile. Click into any project for a full architecture and decision
          breakdown.
        </p>
      </div>
      <a
        href="/projects"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-indigo-300 hover:text-indigo-200"
      >
        See all projects
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14M13 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-2" data-shuffle>
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="max-w-2xl">
      <p class="text-sm font-medium uppercase tracking-widest text-indigo-300">
        What I do
      </p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-white md:text-4xl">
        Specialties
      </h2>
      <p class="mt-2 text-slate-400">
        I own projects end to end: scoping, system design, code, CI/CD,
        Docker, and deployment. Here's where I add the most value.
      </p>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {
        specialties.map((spec) => (
          <div class="rounded-2xl border border-white/10 bg-slate-900/50 p-6 backdrop-blur-sm">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-indigo-500/20 to-purple-500/20 ring-1 ring-indigo-500/30">
              <svg
                class="h-5 w-5 text-indigo-300"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d={spec.icon} />
              </svg>
            </div>
            <h3 class="mt-4 text-lg font-semibold text-white">{spec.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-400">
              {spec.description}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div
      class="theme-cta-section relative overflow-hidden rounded-3xl border border-white/10 p-10 text-center md:p-16"
    >
      <div class="theme-cta-section-glow absolute inset-0"></div>
      <div class="relative">
        <h2
          class="text-3xl font-bold tracking-tight text-white md:text-4xl"
        >
          Have a product that needs to actually ship?
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-slate-300">
          I take vague ideas and turn them into working, well-architected
          products. Let's talk about what you're building.
        </p>
        <a
          href="/contact"
          class="mt-8 inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition-all hover:bg-slate-100"
        >
          Start a conversation
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14M13 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
