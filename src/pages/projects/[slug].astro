---
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

const statusColors: Record<string, string> = {
  Live: "bg-emerald-500/10 text-emerald-300 border-emerald-500/20",
  "Demo-ready": "bg-indigo-500/10 text-indigo-300 border-indigo-500/20",
  "In development": "bg-amber-500/10 text-amber-300 border-amber-500/20",
  "Open source": "bg-sky-500/10 text-sky-300 border-sky-500/20",
};

const caseStudyJsonLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: project.name,
  headline: project.name,
  description: project.tagline,
  image: project.banner
    ? new URL(project.banner, Astro.site).href
    : undefined,
  about: project.category,
  keywords: project.stack.join(", "),
  creator: {
    "@type": "Person",
    name: "Atif Ali",
    url: "https://atifali.pages.dev",
  },
};
---

<Layout
  title={`${project.name} — Atif Ali`}
  description={project.tagline}
  ogImage={project.banner}
  jsonLd={caseStudyJsonLd}
>
  <article class="mx-auto max-w-4xl px-6 pt-16 pb-20 md:pt-24">
    <a
      href="/projects"
      class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-400 transition-colors hover:text-white"
    >
      <svg
        class="h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M19 12H5M11 19l-7-7 7-7"></path>
      </svg>
      All projects
    </a>

    {
      project.banner && (
        <div class="mt-8 overflow-hidden rounded-2xl border border-white/10 shadow-2xl shadow-indigo-500/10">
          <img
            src={project.banner}
            alt={`${project.name} banner`}
            class="w-full"
            width="1600"
            height="1200"
          />
        </div>
      )
    }

    <header class="mt-10">
      <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-widest text-slate-500">
        <span>{project.category}</span>
        <span>·</span>
        <span>{project.year}</span>
        <span
          class:list={[
            "rounded-full border px-2.5 py-1 font-medium",
            statusColors[project.status],
          ]}
        >
          {project.status}
        </span>
      </div>
      <h1
        class="mt-4 text-3xl font-bold tracking-tight text-white md:text-4xl lg:text-5xl"
      >
        {project.name}
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-slate-300">
        {project.tagline}
      </p>

      {
        project.links.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-3">
            {project.links.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 rounded-lg border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-white/10"
              >
                {link.label}
                <svg
                  class="h-3.5 w-3.5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M7 17L17 7M7 7h10v10" />
                </svg>
              </a>
            ))}
          </div>
        )
      }
    </header>

    <div class="mt-10 rounded-2xl border border-white/10 bg-slate-900/40 p-6 backdrop-blur-sm">
      <div class="text-xs uppercase tracking-widest text-slate-500">
        Tech stack
      </div>
      <div class="mt-3 flex flex-wrap gap-2">
        {
          project.stack.map((tech) => (
            <span class="rounded-md bg-slate-800/80 px-2.5 py-1 text-xs font-medium text-slate-200 ring-1 ring-white/5">
              {tech}
            </span>
          ))
        }
      </div>
    </div>

    <section class="mt-16">
      <h2 class="text-2xl font-bold tracking-tight text-white md:text-3xl">
        The problem
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-slate-300">
        {project.hero.problem}
      </p>
    </section>

    <section class="mt-14">
      <h2 class="text-2xl font-bold tracking-tight text-white md:text-3xl">
        Goals
      </h2>
      <ul class="mt-4 space-y-3">
        {
          project.hero.goals.map((goal) => (
            <li class="flex items-start gap-3">
              <div class="mt-1.5 flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-indigo-500/20 ring-1 ring-indigo-400/50">
                <div class="h-1.5 w-1.5 rounded-full bg-indigo-400" />
              </div>
              <span class="text-slate-300">{goal}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-14">
      <h2 class="text-2xl font-bold tracking-tight text-white md:text-3xl">
        The solution
      </h2>
      <ul class="mt-4 grid gap-3 md:grid-cols-2">
        {
          project.hero.solution.map((item) => (
            <li class="rounded-xl border border-white/10 bg-slate-900/40 p-4 text-slate-300">
              {item}
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-14">
      <h2 class="text-2xl font-bold tracking-tight text-white md:text-3xl">
        My role
      </h2>
      <ul class="mt-4 space-y-2 text-slate-300">
        {
          project.hero.role.map((item) => (
            <li class="flex gap-3">
              <span class="text-indigo-400">→</span>
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-14">
      <h2 class="text-2xl font-bold tracking-tight text-white md:text-3xl">
        UI direction
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-slate-300">
        {project.hero.ui}
      </p>
    </section>

    <section class="mt-14">
      <h2 class="text-2xl font-bold tracking-tight text-white md:text-3xl">
        User flows
      </h2>
      <div class="mt-6 space-y-6">
        {
          project.hero.flows.map((flow) => (
            <div class="rounded-2xl border border-white/10 bg-slate-900/40 p-6">
              <h3 class="font-semibold text-white">{flow.title}</h3>
              <ol class="mt-4 space-y-3">
                {flow.steps.map((step, idx) => (
                  <li class="flex items-start gap-3">
                    <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 text-xs font-semibold text-white">
                      {idx + 1}
                    </span>
                    <span class="pt-0.5 text-slate-300">{step}</span>
                  </li>
                ))}
              </ol>
            </div>
          ))
        }
      </div>
    </section>

    {
      project.gallery.length > 0 && (
        <section class="mt-14">
          <h2 class="text-2xl font-bold tracking-tight text-white md:text-3xl">
            Screenshots
          </h2>
          <p class="mt-2 text-sm text-slate-400">Click any image to open at full size.</p>
          <div class="mt-6 grid gap-5 sm:grid-cols-2" id="gallery-grid">
            {project.gallery.map((shot, i) => (
              <figure class="group overflow-hidden rounded-2xl border border-white/10 bg-slate-900/40">
                <button
                  type="button"
                  class="block w-full cursor-zoom-in"
                  data-lightbox-trigger
                  data-lightbox-src={shot.src}
                  data-lightbox-caption={shot.caption}
                  data-lightbox-index={i}
                >
                  <div class="aspect-[16/9] overflow-hidden bg-slate-950 flex items-center justify-center">
                    <img
                      src={shot.src}
                      alt={shot.caption}
                      loading="lazy"
                      class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-[1.02]"
                    />
                  </div>
                </button>
                <figcaption class="border-t border-white/5 px-4 py-3 text-sm text-slate-400">
                  {shot.caption}
                </figcaption>
              </figure>
            ))}
          </div>

          <dialog
            id="gallery-lightbox"
            class="m-0 w-screen h-screen max-w-none max-h-none bg-slate-950/95 p-0 text-white backdrop:bg-slate-950/80"
          >
            <div class="flex h-screen w-screen flex-col">
              <div class="flex items-center justify-between px-6 py-4 border-b border-white/10">
                <span id="lightbox-counter" class="text-sm text-slate-400" />
                <button
                  type="button"
                  id="lightbox-close"
                  aria-label="Close"
                  class="rounded-md border border-white/20 bg-white/5 px-3 py-1.5 text-sm font-medium text-white hover:bg-white/10"
                >
                  Close (Esc)
                </button>
              </div>
              <div class="relative flex-1 overflow-hidden flex items-center justify-center px-2 sm:px-12">
                <button
                  type="button"
                  id="lightbox-prev"
                  aria-label="Previous"
                  class="absolute left-2 top-1/2 -translate-y-1/2 z-10 rounded-full border border-white/20 bg-slate-900/80 p-3 text-white hover:bg-slate-900 sm:left-6"
                >
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 6l-6 6 6 6" />
                  </svg>
                </button>
                <img
                  id="lightbox-image"
                  src=""
                  alt=""
                  class="max-h-full max-w-full object-contain"
                />
                <button
                  type="button"
                  id="lightbox-next"
                  aria-label="Next"
                  class="absolute right-2 top-1/2 -translate-y-1/2 z-10 rounded-full border border-white/20 bg-slate-900/80 p-3 text-white hover:bg-slate-900 sm:right-6"
                >
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 6l6 6-6 6" />
                  </svg>
                </button>
              </div>
              <p id="lightbox-caption" class="px-6 py-4 text-center text-sm text-slate-300 border-t border-white/10" />
            </div>
          </dialog>

          <script is:inline define:vars={{ gallery: project.gallery }}>
            (() => {
              const dialog = document.getElementById("gallery-lightbox");
              if (!dialog) return;
              const img = document.getElementById("lightbox-image");
              const caption = document.getElementById("lightbox-caption");
              const counter = document.getElementById("lightbox-counter");
              const closeBtn = document.getElementById("lightbox-close");
              const prevBtn = document.getElementById("lightbox-prev");
              const nextBtn = document.getElementById("lightbox-next");
              let current = 0;

              function show(i) {
                current = (i + gallery.length) % gallery.length;
                const shot = gallery[current];
                img.src = shot.src;
                img.alt = shot.caption;
                caption.textContent = shot.caption;
                counter.textContent = (current + 1) + " / " + gallery.length;
              }

              document.querySelectorAll("[data-lightbox-trigger]").forEach((el) => {
                el.addEventListener("click", () => {
                  show(parseInt(el.dataset.lightboxIndex, 10));
                  dialog.showModal();
                });
              });

              closeBtn.addEventListener("click", () => dialog.close());
              prevBtn.addEventListener("click", () => show(current - 1));
              nextBtn.addEventListener("click", () => show(current + 1));

              dialog.addEventListener("click", (e) => {
                if (e.target === dialog) dialog.close();
              });

              document.addEventListener("keydown", (e) => {
                if (!dialog.open) return;
                if (e.key === "ArrowLeft") show(current - 1);
                else if (e.key === "ArrowRight") show(current + 1);
              });
            })();
          </script>
        </section>
      )
    }

    <section class="mt-14">
      <h2 class="text-2xl font-bold tracking-tight text-white md:text-3xl">
        Key learnings
      </h2>
      <ul class="mt-4 space-y-3">
        {
          project.hero.learnings.map((item) => (
            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-purple-400"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z" />
              </svg>
              <span class="text-slate-300">{item}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <section
      class="theme-cta-section mt-16 rounded-3xl border border-white/10 p-8 md:p-12"
    >
      <h2 class="text-2xl font-bold tracking-tight text-white">
        Want something like {project.name}?
      </h2>
      <p class="mt-2 text-slate-300">
        I'm open to senior contract work. Let's talk about what you're
        building.
      </p>
      <a
        href="/contact"
        class="mt-6 inline-flex items-center gap-2 rounded-lg bg-white px-5 py-2.5 text-sm font-semibold text-slate-950 transition-all hover:bg-slate-100"
      >
        Get in touch
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14M13 5l7 7-7 7"></path>
        </svg>
      </a>
    </section>
  </article>
</Layout>
