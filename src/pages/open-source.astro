---
import Layout from "../layouts/Layout.astro";

const items = [
  {
    name: "Kong Redis Plugin",
    role: "Author",
    description:
      "Open-source Lua plugin for Kong API Gateway adding Redis-backed response caching with configurable TTL, cache keys, and bypass rules. Drop-in replacement for the built-in proxy-cache plugin when you need shared cache across gateway nodes.",
    tech: ["Lua", "Redis", "Kong Plugin Framework"],
    repo: "https://github.com/atifali-pm/kong-proxy-cache-redis-plugin",
    caseStudy: "/projects/kong-redis-plugin",
  },
  {
    name: "atifali.pages.dev",
    role: "Author",
    description:
      "Source code for this portfolio site. Astro 5 + Tailwind v4, single-source-of-truth content model in TypeScript, dynamic theming, randomized project shuffle, FormSubmit contact form, Cloudflare Pages deploy. MIT.",
    tech: ["Astro 5", "Tailwind v4", "TypeScript", "Cloudflare Pages"],
    repo: "https://github.com/atifali-pm/portfolio",
    caseStudy: null,
  },
  {
    name: "Tracklane",
    role: "Author",
    description:
      "Modern AI-first project management on Rails 8 with Hotwire, Action Cable, and Claude in the core workflow. Self-hostable. MIT planned. Currently in Phase 1.",
    tech: ["Rails 8", "PostgreSQL", "Hotwire", "Claude"],
    repo: "https://github.com/atifali-pm/tracklane",
    caseStudy: "/projects/tracklane",
  },
  {
    name: "n8n Agent Studio",
    role: "Author",
    description:
      "Three production-grade n8n workflows with Claude tool-use, Postgres audit, and shared dashboard. Reference implementation for senior-tier n8n automation.",
    tech: ["n8n", "Claude", "PostgreSQL", "Docker Compose"],
    repo: "https://github.com/atifali-pm/n8n-agent-studio",
    caseStudy: "/projects/n8n-agent-studio",
  },
];
---

<Layout
  title="Open source — Atif Ali"
  description="Public code: Kong Redis caching plugin, this portfolio site, Tracklane (AI-first Rails PM), and the n8n Agent Studio reference workflows."
>
  <section class="mx-auto max-w-4xl px-6 pt-14 pb-8 md:pt-20">
    <p class="text-sm font-medium uppercase tracking-widest text-indigo-300">
      Open source
    </p>
    <h1
      class="mt-2 text-3xl font-bold tracking-tight text-white md:text-4xl lg:text-5xl"
    >
      Code I've shipped <span class="gradient-text">in public</span>
    </h1>
    <p class="mt-4 max-w-2xl text-base text-slate-400">
      Public repos I author or maintain. The Kong plugin runs in real
      production deployments. The portfolio site, Tracklane, and Agent
      Studio are open by design so anyone can audit the patterns I use.
    </p>
  </section>

  <section class="mx-auto max-w-4xl px-6 pb-20">
    <div class="space-y-5">
      {
        items.map((item) => (
          <article class="rounded-2xl border border-white/10 bg-slate-900/40 p-6 backdrop-blur-sm md:p-8">
            <div class="flex flex-wrap items-baseline justify-between gap-3">
              <div>
                <h2 class="text-xl font-semibold text-white md:text-2xl">
                  {item.name}
                </h2>
                <p class="mt-1 text-xs uppercase tracking-widest text-indigo-300">
                  {item.role}
                </p>
              </div>
              <a
                href={item.repo}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1.5 rounded-lg border border-white/10 bg-white/5 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-white/10"
              >
                <svg
                  class="h-3.5 w-3.5"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path d="M12 .5C5.4.5 0 5.9 0 12.6c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.6.1-3.3 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.2 3 .1 3.3.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6C20.6 22.4 24 17.9 24 12.6 24 5.9 18.6.5 12 .5z" />
                </svg>
                GitHub
              </a>
            </div>
            <p class="mt-4 leading-relaxed text-slate-300">
              {item.description}
            </p>
            <div class="mt-5 flex flex-wrap gap-1.5">
              {item.tech.map((t) => (
                <span class="rounded-md bg-slate-800/60 px-2 py-0.5 text-[11px] text-slate-300 ring-1 ring-white/5">
                  {t}
                </span>
              ))}
            </div>
            {item.caseStudy && (
              <a
                href={item.caseStudy}
                class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-indigo-300 transition-colors hover:text-indigo-200"
              >
                Read the case study
                <svg
                  class="h-4 w-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M5 12h14M13 5l7 7-7 7" />
                </svg>
              </a>
            )}
          </article>
        ))
      }
    </div>
  </section>
</Layout>
