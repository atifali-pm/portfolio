---
import Layout from "../layouts/Layout.astro";

const sent = Astro.url.searchParams.get("sent") === "1";

const channels = [
  {
    name: "Email",
    value: "aatifali21@gmail.com",
    href: "mailto:aatifali21@gmail.com",
    description: "Best for detailed project briefs, NDAs, or anything that needs a paper trail.",
    icon: "M4 6a2 2 0 012-2h12a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm0 0l8 7 8-7",
  },
  {
    name: "LinkedIn",
    value: "linkedin.com/in/-atifali-",
    href: "https://www.linkedin.com/in/-atifali-/",
    description: "Connect professionally, send InMail, or follow my posts.",
    icon: "M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 2a2 2 0 110 4 2 2 0 010-4z",
  },
  {
    name: "GitHub",
    value: "github.com/atifali-pm",
    href: "https://github.com/atifali-pm",
    description: "Code for every project on this site, plus open-source contributions.",
    icon: "M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22",
  },
  {
    name: "Upwork",
    value: "upwork.com/freelancers/~014858668202b87161",
    href: "https://www.upwork.com/freelancers/~014858668202b87161",
    description: "Verified Upwork profile with proposal history and client reviews.",
    icon: "M20 7v10a3 3 0 01-3 3H7a3 3 0 01-3-3V7a3 3 0 013-3h10a3 3 0 013 3zM8 11a3 3 0 116 0 4 4 0 004 4",
  },
  {
    name: "Fiverr",
    value: "fiverr.com/aatif_ali",
    href: "https://www.fiverr.com/aatif_ali",
    description: "Fixed-scope gigs across Laravel, APIs, AI integrations, and SaaS builds.",
    icon: "M6 4h12M6 4v6a6 6 0 006 6v4M6 4v.01M14 8h4",
  },
  {
    name: "Contra",
    value: "contra.com/atif_ali_awtxw4wu",
    href: "https://contra.com/atif_ali_awtxw4wu/work",
    description: "Long-form case studies with visuals for each major project.",
    icon: "M12 2a10 10 0 100 20 10 10 0 000-20zm0 5v10M7 12h10",
  },
];
---

<Layout title="Contact — Atif Ali" description="Open to senior contract work across multi-tenant SaaS, AI platforms, fintech, and APIs at scale. Reply within 24 hours.">
  <section class="mx-auto max-w-3xl px-6 pt-14 pb-8 md:pt-20">
    <p class="text-sm font-medium uppercase tracking-widest text-indigo-300">
      Contact
    </p>
    <h1
      class="mt-2 text-3xl font-bold tracking-tight text-white md:text-4xl lg:text-5xl"
    >
      Let's <span class="gradient-text">talk</span>.
    </h1>
    <p class="mt-5 text-lg leading-relaxed text-slate-300">
      I'm open to senior contract work across multi-tenant SaaS, AI
      platforms, fintech, and API products. Send me a message and I'll get
      back to you within 24 hours.
    </p>
  </section>

  {
    sent && (
      <section class="mx-auto max-w-3xl px-6 pb-2">
        <div class="flex items-start gap-3 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 p-5 text-emerald-200">
          <svg
            class="mt-0.5 h-5 w-5 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M22 11.08V12a10 10 0 11-5.93-9.14M22 4L12 14.01l-3-3" />
          </svg>
          <div>
            <h3 class="font-semibold text-white">Message sent.</h3>
            <p class="mt-1 text-sm">
              Thanks for reaching out. I'll reply within 24 hours.
            </p>
          </div>
        </div>
      </section>
    )
  }

  <section class="mx-auto max-w-3xl px-6 py-10">
    <form
      action="https://formsubmit.co/aatifali21@gmail.com"
      method="POST"
      class="rounded-2xl border border-white/10 bg-slate-900/40 p-6 backdrop-blur-sm md:p-8"
    >
      <input type="hidden" name="_subject" value="New message from atifali.pages.dev" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_next" value="https://atifali.pages.dev/contact?sent=1" />
      <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

      <div class="grid gap-5 md:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium text-slate-300">Name</span>
          <input
            type="text"
            name="name"
            required
            autocomplete="name"
            class="mt-2 block w-full rounded-lg border border-white/10 bg-slate-950/60 px-4 py-2.5 text-white placeholder:text-slate-500 focus:border-indigo-500/50 focus:outline-none focus:ring-2 focus:ring-indigo-500/30"
            placeholder="Your name"
          />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-slate-300">Email</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="mt-2 block w-full rounded-lg border border-white/10 bg-slate-950/60 px-4 py-2.5 text-white placeholder:text-slate-500 focus:border-indigo-500/50 focus:outline-none focus:ring-2 focus:ring-indigo-500/30"
            placeholder="you@example.com"
          />
        </label>
      </div>

      <label class="mt-5 block">
        <span class="text-sm font-medium text-slate-300">Company <span class="text-slate-500">(optional)</span></span>
        <input
          type="text"
          name="company"
          autocomplete="organization"
          class="mt-2 block w-full rounded-lg border border-white/10 bg-slate-950/60 px-4 py-2.5 text-white placeholder:text-slate-500 focus:border-indigo-500/50 focus:outline-none focus:ring-2 focus:ring-indigo-500/30"
          placeholder="Company or product name"
        />
      </label>

      <label class="mt-5 block">
        <span class="text-sm font-medium text-slate-300">Project type</span>
        <select
          name="project_type"
          required
          class="mt-2 block w-full rounded-lg border border-white/10 bg-slate-950/60 px-4 py-2.5 text-white focus:border-indigo-500/50 focus:outline-none focus:ring-2 focus:ring-indigo-500/30"
        >
          <option value="">Select one</option>
          <option>Multi-tenant SaaS build</option>
          <option>AI / LLM platform</option>
          <option>Fintech or payments</option>
          <option>API / backend at scale</option>
          <option>Mobile app (React Native)</option>
          <option>Rescue or refactor an existing project</option>
          <option>Other</option>
        </select>
      </label>

      <label class="mt-5 block">
        <span class="text-sm font-medium text-slate-300">Message</span>
        <textarea
          name="message"
          required
          rows="6"
          minlength="20"
          class="mt-2 block w-full rounded-lg border border-white/10 bg-slate-950/60 px-4 py-2.5 text-white placeholder:text-slate-500 focus:border-indigo-500/50 focus:outline-none focus:ring-2 focus:ring-indigo-500/30"
          placeholder="Tell me about what you're building, where you are in the project, any stack preferences, and rough timeline and budget."
        ></textarea>
      </label>

      <div class="mt-6 flex flex-col-reverse items-start gap-4 md:flex-row md:items-center md:justify-between">
        <p class="text-xs text-slate-500">
          Never shared. Replies typically within 24 hours.
        </p>
        <button
          type="submit"
          class="theme-cta group inline-flex items-center justify-center gap-2 rounded-lg px-6 py-2.5 text-sm font-semibold text-white transition-all"
        >
          Send message
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14M13 5l7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </form>

    <div
      class="mt-8 rounded-2xl border border-white/10 bg-slate-900/30 p-6 text-sm text-slate-400"
    >
      <h3 class="font-semibold text-white">What a good first message looks like</h3>
      <ul class="mt-3 space-y-1.5">
        <li>· A few sentences on what you're building or trying to solve</li>
        <li>· Where you are: idea, MVP, scaling, rescuing a stuck project</li>
        <li>· Stack preferences or constraints if you already have them</li>
        <li>· Rough timeline and budget range</li>
      </ul>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 pb-20">
    <div class="mb-6">
      <h2 class="text-xl font-semibold text-white">Or reach me another way</h2>
    </div>
    <div class="grid gap-4">
      {
        channels.map((channel) => (
          <a
            href={channel.href}
            target="_blank"
            rel="noopener"
            class="group flex items-start gap-5 rounded-2xl border border-white/10 bg-slate-900/40 p-6 backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:border-indigo-500/40 hover:bg-slate-900/70"
          >
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500/20 to-purple-500/20 ring-1 ring-indigo-500/30">
              <svg
                class="h-6 w-6 text-indigo-300"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d={channel.icon} />
              </svg>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <h3 class="text-lg font-semibold text-white">
                  {channel.name}
                </h3>
                <svg
                  class="h-4 w-4 text-slate-500 transition-all group-hover:translate-x-0.5 group-hover:text-indigo-300"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M7 17L17 7M7 7h10v10" />
                </svg>
              </div>
              <p class="text-sm font-mono text-indigo-300">{channel.value}</p>
              <p class="mt-2 text-sm text-slate-400">
                {channel.description}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
